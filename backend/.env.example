# Copy this file to `.env` and fill in your key for local development.

# Google Gemini (required) — get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# LLM model (optional, defaults to gemini-2.5-flash)
LLM_MODEL=gemini-2.5-flash

# Allowed frontend origin for CORS (local dev default is fine)
FRONTEND_URL=http://localhost:3000

# NOTE: Album art + song verification use the free iTunes Search API, which needs
# no account or API key. Nothing else to configure.

# ---- Frontend (Next.js) ----
# URL of the Python backend. For local dev this is the FastAPI server below.
PYTHON_BACKEND_URL=http://localhost:8000

# App display name
NEXT_PUBLIC_APP_NAME=Music Buddy

# ---- Backend (Python / FastAPI) ----
# These belong in backend/.env (see backend/.env.example). Listed here for reference.
# GEMINI_API_KEY=          # required — https://aistudio.google.com/apikey
# LLM_MODEL=gemini-2.5-flash
# Album art uses the free iTunes Search API — no key/account required.
